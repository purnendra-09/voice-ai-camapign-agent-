# Application Environment
ENVIRONMENT=development
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Google Sheets Configuration
# Path to Google Service Account JSON credentials
GOOGLE_SHEETS_CREDENTIALS_PATH=app/credentials/google-service-account.json

# Render/hosted deployments can use this instead of a local credentials file.
# Paste the complete Google service-account JSON as one environment variable.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional but recommended: spreadsheet ID from the Google Sheets URL.
# Example URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=1_C4jx5XFMKErjwnb0ZVKtMakfhnK4wNVAd0v4amsEvo

# Name of your Google Sheet (the document name, not the URL)
# Example: "Hospital_Appointments"
# Used only when GOOGLE_SHEET_ID is empty.
GOOGLE_SHEET_NAME=Hospital_Appointments

# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# Groq/OpenAI-compatible provider
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# AI Generation Configuration
TEMPERATURE=0.7
MAX_TOKENS=1000

# CORS Configuration
# For production, restrict to your frontend domain
CORS_ORIGINS=["*"]
CORS_CREDENTIALS=False
CORS_METHODS=["*"]
CORS_HEADERS=["*"]
